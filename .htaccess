# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php74" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ============================================================
# CLEAN URL REWRITES
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (kalau SSL aktif)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Protect hidden files, config, sql
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.htaccess$ - [F,L]
    RewriteRule ^\.gitignore$ - [F,L]
    RewriteRule ^\.cpanel\.yml$ - [F,L]
    RewriteRule \.sql$ - [F,L]
    RewriteRule ^config/ - [F,L]

    # Redirect .php URLs ke clean URL (301) — kecuali admin, ajax, migrations, process endpoints, sitemap
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteCond %{REQUEST_URI} !^/(admin|ajax|migrations)/
    RewriteCond %1 !^(index|process-contact|process-download|sitemap\.xml)$
    RewriteRule ^ /%1 [R=301,L,NE]

    # Redirect /index atau /index.php ke root
    RewriteCond %{THE_REQUEST} \s/+index(\.php)?[\s?] [NC]
    RewriteRule ^ / [R=301,L]

    # Clean URL rewrites — specific routes dulu
    RewriteRule ^category/([^/]+)/?$       category-brands.php?slug=$1       [L,QSA]
    RewriteRule ^brand/([^/]+)/?$          brand-detail.php?slug=$1          [L,QSA]
    RewriteRule ^training/([0-9]+)/?$      training-detail.php?id=$1         [L,QSA]
    RewriteRule ^training/?$               training-services.php             [L,QSA]
    RewriteRule ^trainings/?$              trainings.php                     [L,QSA]
    RewriteRule ^downloads/?$              downloads.php                     [L,QSA]
    RewriteRule ^contact/?$                contact.php                       [L,QSA]
    RewriteRule ^products/?$               products.php                      [L,QSA]
    RewriteRule ^brands/?$                 brands.php                        [L,QSA]
    RewriteRule ^clients/?$                clients.php                       [L,QSA]
    RewriteRule ^categories/?$             categories.php                    [L,QSA]
    RewriteRule ^sitemap\.xml$             sitemap.xml.php                   [L]

    # Generic fallback: /foo -> /foo.php kalau file ada (buat halaman lain)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/$1.php -f
    RewriteRule ^([^/]+)/?$ /$1.php [L,QSA]
</IfModule>

# ============================================================
# GZIP COMPRESSION (page speed = SEO)
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json application/xml image/svg+xml
</IfModule>

# ============================================================
# BROWSER CACHING (page speed = SEO)
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType application/font-woff2  "access plus 1 year"
    ExpiresDefault                        "access plus 2 days"
</IfModule>

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Custom 404
ErrorDocument 404 /404.php
